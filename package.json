{
  "name": "chatbotweb-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "api:install": "python -m pip install -r apps/api/requirements.txt",
    "api:dev": "cd apps/api && uvicorn app.main:app --reload",
    "api:test": "cd apps/api && python -m pytest",
    "api:db:upgrade": "cd apps/api && python -m alembic upgrade head",
    "web:install": "npm --prefix apps/web install",
    "web:dev": "npm --prefix apps/web run dev",
    "web:test": "npm --prefix apps/web run test:run",
    "web:lint": "npm --prefix apps/web run lint",
    "web:build": "npm --prefix apps/web run build",
    "widget-sdk:install": "npm --prefix packages/widget-sdk install",
    "widget-sdk:test": "npm --prefix packages/widget-sdk run test",
    "widget-sdk:lint": "npm --prefix packages/widget-sdk run lint",
    "widget-sdk:build": "npm --prefix packages/widget-sdk run build",
    "widget:install": "npm --prefix apps/widget install",
    "widget:test": "npm --prefix apps/widget run test",
    "widget:lint": "npm --prefix apps/widget run lint",
    "widget:build": "npm --prefix apps/widget run build",
    "verify": "docker compose config && npm run api:test && npm run web:test && npm run web:lint && npm run web:build && npm run widget-sdk:test && npm run widget-sdk:lint && npm run widget-sdk:build && npm run widget:test && npm run widget:lint && npm run widget:build"
  }
}
