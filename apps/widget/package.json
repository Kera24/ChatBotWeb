{
    "name":  "@yoranix/widget-app",
    "version":  "0.1.0-handshake.0",
    "private":  true,
    "type":  "module",
    "scripts":  {
                    "dev":  "vite --host 0.0.0.0 --port 4301",
                    "build":  "vite build \u0026\u0026 tsc --noEmit -p tsconfig.json \u0026\u0026 node scripts/check-size.mjs",
                    "lint":  "tsc --noEmit -p tsconfig.json",
                    "test":  "vitest run",
                    "build:test":  "vite build --mode test \u0026\u0026 tsc --noEmit -p tsconfig.json \u0026\u0026 node scripts/check-size.mjs"
                },
    "dependencies":  {
                         "@yoranix/widget-sdk":  "file:../../packages/widget-sdk"
                     },
    "devDependencies":  {
                            "@types/node":  "latest",
                            "jsdom":  "latest",
                            "typescript":  "latest",
                            "vite":  "latest",
                            "vitest":  "latest",
                            "esbuild":  "latest"
                        }
}