{
  "name": "@yoranix/widget-browser-tests",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "playwright test --project=chromium",
    "test:chromium": "playwright test --project=chromium --grep-invert @release",
    "test:extended": "playwright test --grep-invert @release",
    "install:browsers": "playwright install chromium",
    "test:a11y": "playwright test specs/accessibility-release.spec.ts --project=chromium",
    "test:visual": "playwright test specs/visual-regression.spec.ts --project=visual-chromium",
    "test:visual:update": "playwright test specs/visual-regression.spec.ts --project=visual-chromium --update-snapshots",
    "test:release": "playwright test specs/versioned-release.spec.ts --project=chromium"
  },
  "devDependencies": {
    "@playwright/test": "latest",
    "typescript": "latest"
  }
}
