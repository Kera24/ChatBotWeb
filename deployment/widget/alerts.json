{
  "schema_version": "1.0",
  "description": "Provider-neutral widget pilot alert definitions. Adapt thresholds to the selected monitoring backend without logging message content.",
  "alerts": [
    {
      "alert_id": "widget-public-service-unavailable",
      "severity": "critical",
      "signal": "liveness or readiness probe failure",
      "threshold": "3 consecutive failures",
      "evaluation_window": "5 minutes",
      "consecutive_failures": 3,
      "runbook": "docs/06_Operations/Widget_Incident_Response_Runbook.md"
    },
    {
      "alert_id": "widget-public-api-5xx-spike",
      "severity": "critical",
      "signal": "public widget API 5xx rate",
      "threshold": ">5% over baseline",
      "evaluation_window": "10 minutes",
      "consecutive_failures": 2,
      "runbook": "docs/06_Operations/Widget_Incident_Response_Runbook.md"
    },
    {
      "alert_id": "widget-synthetic-smoke-failure",
      "severity": "incident",
