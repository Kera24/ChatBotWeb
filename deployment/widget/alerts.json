      "evaluation_window": "30 minutes",
      "consecutive_failures": 2,
      "runbook": "docs/06_Operations/Widget_Pilot_Verification_Runbook.md"
    },
    {
      "alert_id": "widget-message-error-spike",
      "severity": "incident",
      "signal": "public message route safe failure category rate",
      "threshold": ">10% over 15 minutes",
