# Local development defaults only.
# Copy to .env for local Docker Compose overrides.
# Do not use these values in production.

POSTGRES_DB=chatbotweb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# Host-machine API commands can use localhost.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/chatbotweb

# Docker Compose API service uses the internal postgres hostname.
API_DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/chatbotweb
API_PORT=8000
API_V1_PREFIX=/api/v1
PHASE=mvp-foundation
SERVICE_NAME=chatbotweb-api

WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_DEVELOPMENT_ORGANISATION_ID=replace-with-local-organisation-id
NEXT_PUBLIC_DEVELOPMENT_WORKSPACE_ID=replace-with-local-workspace-id
NEXT_PUBLIC_DEVELOPMENT_USER_EMAIL=dev-super-admin@example.test
NEXT_PUBLIC_DEVELOPMENT_ROLE=super_admin

# Public Access distributed rate limiting. Development placeholder only; set a secret value outside git for real deployments.
RATE_LIMIT_IDENTITY_SECRET=dev-rate-limit-identity-secret-change-me
RATE_LIMIT_REDIS_PREFIX=rate
RATE_LIMIT_REDIS_TIMEOUT_SECONDS=0.2
RATE_LIMIT_LOCAL_FALLBACK_ENABLED=false
TRUSTED_PROXY_NETWORKS=
# Public Access anonymous sessions. Development placeholders only; set real secrets outside git for deployments.
PUBLIC_SESSION_TOKEN_HASH_SECRET=dev-public-session-token-secret-change-me
PUBLIC_SESSION_TOKEN_VERSION=v1
PUBLIC_SESSION_TOKEN_ID_BYTES=16
PUBLIC_SESSION_SECRET_BYTES=32
