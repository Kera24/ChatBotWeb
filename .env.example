# Local development defaults only.
# Copy to .env for local Docker Compose overrides.
# Do not use these values in production.

POSTGRES_DB=chatbotweb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# Host-machine API commands can use localhost.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/chatbotweb

# Docker Compose API service uses the internal postgres hostname.
API_DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/chatbotweb
API_PORT=8000
API_V1_PREFIX=/api/v1
PHASE=mvp-foundation
SERVICE_NAME=chatbotweb-api

WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_DEVELOPMENT_ORGANISATION_ID=replace-with-local-organisation-id
NEXT_PUBLIC_DEVELOPMENT_WORKSPACE_ID=replace-with-local-workspace-id
NEXT_PUBLIC_DEVELOPMENT_USER_EMAIL=dev-super-admin@example.test
NEXT_PUBLIC_DEVELOPMENT_ROLE=super_admin

# Public Access distributed rate limiting. Development placeholder only; set a secret value outside git for real deployments.
RATE_LIMIT_IDENTITY_SECRET=dev-rate-limit-identity-secret-change-me
RATE_LIMIT_REDIS_PREFIX=rate
RATE_LIMIT_REDIS_TIMEOUT_SECONDS=0.2
RATE_LIMIT_LOCAL_FALLBACK_ENABLED=false
TRUSTED_PROXY_NETWORKS=
# Public Access anonymous sessions. Development placeholders only; set real secrets outside git for deployments.
PUBLIC_SESSION_TOKEN_HASH_SECRET=dev-public-session-token-secret-change-me
PUBLIC_SESSION_TOKEN_VERSION=v1
PUBLIC_SESSION_TOKEN_ID_BYTES=16
PUBLIC_SESSION_SECRET_BYTES=32
# Public widget configuration asset projection. Optional development placeholder; production must use HTTPS.
PUBLIC_WIDGET_ASSET_BASE_URL=https://assets.example.test/widgets
# Public widget message preparation. Development placeholders only; set real secrets outside git for deployments.
PUBLIC_MESSAGE_IDEMPOTENCY_HASH_SECRET=dev-public-message-idempotency-secret-change-me
PUBLIC_MESSAGE_IDEMPOTENCY_TTL_SECONDS=86400
PUBLIC_MESSAGE_IDEMPOTENCY_KEY_MIN_LENGTH=16
PUBLIC_MESSAGE_IDEMPOTENCY_KEY_MAX_LENGTH=160
PUBLIC_MESSAGE_MAX_CHARACTERS=4000
PUBLIC_MESSAGE_MAX_BYTES=12288
PUBLIC_MESSAGE_METADATA_MAX_ITEMS=10
PUBLIC_MESSAGE_METADATA_KEY_MAX_LENGTH=60
PUBLIC_MESSAGE_METADATA_VALUE_MAX_LENGTH=240

# Public widget message abuse/cost controls. Development defaults only.
PUBLIC_MESSAGE_MAX_INPUT_TOKENS=1200
PUBLIC_MESSAGE_DEFAULT_MODEL_KEY=mock-grounded-answer
PUBLIC_MESSAGE_REPEATED_LOOKBACK_COUNT=20
PUBLIC_MESSAGE_RESTRICTED_RETRIEVAL_LIMIT=2
PUBLIC_MESSAGE_RESTRICTED_CONTEXT_CHARACTERS=4000
PUBLIC_MESSAGE_RESTRICTED_OUTPUT_TOKENS=250
PUBLIC_MESSAGE_DAILY_MESSAGE_QUOTA=0
PUBLIC_MESSAGE_DAILY_TOKEN_QUOTA=0
PUBLIC_MESSAGE_DAILY_COST_QUOTA=
# Widget controlled-pilot release artifact validation placeholders.
# Production deployment must provide real HTTPS origins; local/test may use localhost through explicit non-production mode.
WIDGET_RELEASE_ENVIRONMENT=pilot
WIDGET_RELEASE_CHANNEL=pilot
WIDGET_PUBLIC_ORIGIN=https://widget.example.com
WIDGET_PUBLIC_API_ORIGIN=https://widget-api.example.com
WIDGET_SDK_PUBLIC_ORIGIN=https://cdn.example.com
